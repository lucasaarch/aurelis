{
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "css.lint.unknownAtRules": "ignore",
    "remote.forwardOnOpen": true,
    "remote.autoForwardPorts": false,
    "remote.portsAttributes": {
        "5432": {
            "label": "postgres",
            "onAutoForward": "silent"
        },
        "6379": {
            "label": "redis",
            "onAutoForward": "silent"
        },
        "8080": {
            "label": "api-server (http)",
            "onAutoForward": "silent",
        },
        "50051": {
            "label": "api-server (grpc)",
            "onAutoForward": "silent",
        },
        "5000": {
            "label": "game-server",
            "onAutoForward": "silent"
        },
    },
}