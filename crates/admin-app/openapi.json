  "components": {
    "schemas": {
      "AccountSummary": {
        "type": "object",
        "required": [
          "id",
          "email",
          "isAdmin",
          "createdAt"
        ],
        "properties": {
          "createdAt": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "isAdmin": {
            "type": "boolean"
          }
        }
      },
      "CreateMobDropRateRequest": {
        "type": "object",
