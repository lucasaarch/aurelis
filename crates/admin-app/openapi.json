  "paths": {
    "/admin/items": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "list_items",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default: 1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Items per page (default: 20)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "class",
            "in": "query",
            "description": "Filter by class",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rarity",
            "in": "query",
            "description": "Filter by rarity",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "equipmentSlot",
            "in": "query",
            "description": "Filter by equipment slot",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inventoryType",
            "in": "query",
            "description": "Filter by inventory type",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "levelMin",
            "in": "query",
            "description": "Minimum level requirement",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "levelMax",
            "in": "query",
            "description": "Maximum level requirement",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search by name",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Items listed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListItemsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/admin/items/{slug}": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "get_item",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "description": "Item slug",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemDetailsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/admin/mob-drop-rates": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "create_mob_drop_rate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMobDropRateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Mob drop rate created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateMobDropRateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
