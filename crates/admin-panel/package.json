{
    "name": "admin-panel",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "format": "biome format --write",
        "lint": "biome check",
        "gen:openapi": "cargo run -p api-server --bin gen_openapi --release > openapi.json",
        "codegen": "pnpm dlx openapi-typescript-codegen --input openapi.json --output src/lib/api --client fetch --useOptions",
        "codegen:all": "pnpm run gen:openapi && pnpm run codegen"
    },
    "dependencies": {
        "@fontsource-variable/geist": "^5.2.8",
        "@hookform/resolvers": "^5.2.2",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-http": "~2.5.7",
        "@tauri-apps/plugin-opener": "^2",
        "@tauri-apps/plugin-window-state": "~2.4.1",
        "@xyflow/react": "^12.10.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "radix-ui": "^1.4.3",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.71.2",
        "shadcn": "^4.0.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@tauri-apps/cli": "^2",
        "@types/node": "^25.4.0",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.6.0",
        "typescript": "~5.8.3",
        "vite": "^7.0.4"
    }
}
